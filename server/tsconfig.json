{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2021",

    "types": ["node"],

    "sourceMap": true,

    "strict": true,

    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    "isolatedModules": true,

    "esModuleInterop": true,

    "skipLibCheck": true
  },

  "include": ["src/**/*.ts", "src/@types/**/*.ts"],

  "exclude": ["node_modules", "dist", "test", "**/*spec.ts"]
}